```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map

# Logs and temp files
*.log
*.tmp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.coverage.*
.pytest_cache/
.mypy_cache/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db

# Distribution / packaging
*.tar*
*.zip
*.rar
*.gz
*.bz2
*.xz
*.7z

# Testing
coverage/
.nyc_output/
istanbul/
.jest/

# IDE
*.swp
*.swo
*~

# Compiled Binary files
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```